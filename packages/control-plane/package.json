  },
  "dependencies": {
    "@bowline/contracts": "workspace:*",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "convex": "^1.42.0",
    "convex-test": "^0.0.53",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
