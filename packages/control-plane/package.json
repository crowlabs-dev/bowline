{
  "name": "@bowline/control-plane",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./devices": {
      "types": "./dist/devices/index.d.ts",
      "default": "./dist/devices/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
